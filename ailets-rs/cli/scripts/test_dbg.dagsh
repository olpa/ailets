# Test script: dbg self-pause and general suspend/resume
#
# Part 1: dbg actor self-pause
#   shell_input -> dbg (pauses after 2 bytes, then resumes)
#
# Part 2: general suspend/resume on a cat actor
#   shell_input -> cat (suspended externally, then resumed)

# === Part 1: dbg actor self-pause ===

set src = node add shell_input --explain="Data source"
set proc = node add dbg --bytes=2 --explain="Pauses after 2 bytes"
dep $proc $src

show

# Pre-enqueue all data before run (avoids timing issues)
write $src "hello"
close $src

# Run in background, immediately resume dbg (resume is idempotent if dbg
# hasn't paused yet - dbg_control state is set to Running, so wait_for_resume
# will return immediately when dbg reaches it)
run $proc --bg
resume $proc
fg

status

# === Part 2: general suspend/resume on cat actor ===

reset

set src = node add shell_input --explain="Data source"
set proc = node add cat --explain="Passthrough - will be suspended externally"
dep $proc $src

show

# Start run in background; cat immediately blocks waiting for shell_input data
run $proc --bg

# Suspend cat - it will block at the next I/O yield point
suspend $proc

# Feed data and close shell_input; cat reads it but then suspends after the read
write $src "hello world"
close $src

# Cat is now suspended - verify
status

# Resume cat; it processes the buffered data and exits
resume $proc
fg

status
